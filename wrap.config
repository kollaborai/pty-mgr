{
  "adapters": {
    "claude": {
      "command": "claude",
      "defaultArgs": ["--dangerously-skip-permissions"],
      "roots": [
        "${home}/.claude/projects/${projectKey}",
        "${home}/.claude/projects"
      ],
      "sessionTimestampPaths": ["timestamp"],
      "assistant": {
        "where": {
          "type": "assistant"
        },
        "complete": {
          "stop_reason": "end_turn"
        },
        "text": [
          {
            "array": "message.content",
            "where": {
              "type": "text"
            },
            "path": "text"
          }
        ]
      }
    },
    "codex": {
      "command": "codex",
      "defaultArgs": ["--yolo"],
      "roots": [
        "${home}/.codex/sessions",
        "${home}/.codex/archived_sessions"
      ],
      "sessionTimestampPaths": ["payload.timestamp", "timestamp"],
      "assistant": {
        "where": {
          "type": "response_item",
          "payload.type": "message",
          "payload.role": "assistant"
        },
        "text": [
          {
            "array": "payload.content",
            "where": {
              "type": "output_text"
            },
            "path": "text"
          }
        ]
      },
      "stripPatterns": [
        "\\n*<oai-mem-citation>[\\s\\S]*?</oai-mem-citation>\\s*$"
      ]
    }
  },
  "logs": {
    "codex": {
      "mainTranscripts": "${home}/.codex/sessions",
      "archivedTranscripts": "${home}/.codex/archived_sessions",
      "sqliteEventStore": "${home}/.codex/logs_2.sqlite",
      "quickFind": "find ~/.codex/sessions ~/.codex/archived_sessions -name '*.jsonl'"
    },
    "claudeCode": {
      "projectTranscripts": "${home}/.claude/projects",
      "projectTranscriptPattern": "${home}/.claude/projects/${projectKey}/<uuid>.jsonl",
      "globalHistory": "${home}/.claude/history.jsonl",
      "sessionState": "${home}/.claude/sessions"
    }
  }
}
